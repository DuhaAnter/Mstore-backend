generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// notes:

//Using OrderItem with priceAtPurchase means that if you raise the price of a t-shirt tomorrow, your sales reports for today won't break.
//Linking the Cart and Order to the Variant instead of the Product is the "secret sauce" for clothing stores. it ensures the warehouse knows exactly which size and color were purchased.

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  role             userRole  @default(USER)
  favoriteProducts Product[]
  reviews          Review[]
  orders           Order[]
  cart             Cart?
  stripeCustomerId String?       // The ID of the "Customer" object in Stripe
  paymentCards PaymentCard[]
}

model PaymentCard {
  id           String     @id @default(uuid())
  token        String  
  last4        String  
  brand        String  
  expMonth     Int
  expYear      Int
  userId       String
  user         User    @relation(fields: [userId], references: [id])
}

model Cart {
  id     String     @id @default(uuid())
  user   User       @relation(fields: [userId], references: [id])
  userId String     @unique
  items  CartItem[] // Use a separate model for items in the cart
}

model CartItem {
  id        String  @id @default(uuid())
  cart      Cart    @relation(fields: [cartId], references: [id])
  cartId    String
  variant   Variant @relation(fields: [variantId], references: [id])
  variantId String
  quantity  Int     @default(1)
}

enum userRole {
  USER
  ADMIN
}

model Product {
  id            String    @id @default(uuid())
  title         String
  description   String?
  imageURL      String
  stock         Int
  favoritedBy   User[]
  reviews       Review[]
  variants      Variant[]
  // 1. These fields store the "Address" to the Category/SubCategory pair
  categoryId    String
  subCategoryId String

  // 2. This creates the official link
  categoryGroup CatSubCategory @relation(fields: [categoryId, subCategoryId], references: [categoryId, subCategoryId])
}

model Category {
  id            String           @id @default(uuid())
  name          String
  // Opposite relation field added here
  subCategories CatSubCategory[]
}

model SubCategory {
  id         String           @id @default(uuid())
  name       String
  // Opposite relation field added here
  categories CatSubCategory[]
}

model CatSubCategory {
  categoryId    String
  subCategoryId String

  category    Category    @relation(fields: [categoryId], references: [id])
  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])

  products Product[]

  // This creates the composite primary key
  @@id([categoryId, subCategoryId])
}

model Variant {
  id         String      @id @default(uuid())
  color      String
  price      Float
  size       String
  product    Product     @relation(fields: [productId], references: [id])
  productId  String
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Review {
  id        String   @id @default(uuid())
  starts    Float
  content   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  // This ensures a user can't spam reviews on a single product
  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(uuid())
  total           Float
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  shippingAddress String
  items           OrderItem[]
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  couponId        String?
  status          orderStatus  @default(PENDING)
}

enum orderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}
model OrderItem {
  id              String  @id @default(uuid())
  order           Order   @relation(fields: [orderId], references: [id])
  orderId         String
  variant         Variant @relation(fields: [variantId], references: [id])
  variantId       String
  quantity        Int
  priceAtPurchase Float // Crucial for record keeping!
}

model Coupon {
  id        String   @id @default(uuid())
  code      String   @unique
  discount  Float
  expiresAt DateTime
  orders    Order[]
}
